<?xml version="1.0" encoding="utf-8"?>
<!--
  AutoCAD ApplicationPlugin bundle manifest.
  Place the entire LightingAI.bundle/ folder in:
    %APPDATA%\Autodesk\ApplicationPlugins\
  AutoCAD 2020–2025 will auto-load it on next launch.
-->
<ApplicationPackage
    SchemaVersion="1.0"
    ProductType="Application"
    AppName="LightingAI Plugin"
    AppVersion="1.0.0"
    AppDescription="Automated MIKA80-E luminaire placement for Rossmann Deckenrasterplan"
    Author="lighting-ai"
    ProductCode="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}">

  <CompanyDetails
      Name="lighting-ai / MAX FRANKE.led"
      Email="info@max-franke.de"
      Url="https://www.max-franke.com"/>

  <Components>

    <!-- AutoCAD 2020 (R23) through 2024 (R24) — .NET Framework 4.8 build -->
    <RuntimeRequirements OS="Win32_64" Platform="AutoCAD"
                         SeriesMin="R23.0" SeriesMax="R24.3"/>
    <ComponentEntry
        AppName="LightingAI.Plugin"
        Version="1.0.0"
        ModuleName="./Contents/LightingAI.Plugin.dll"
        LoadOnCommandInvocation="false"
        LoadOnAutoCADStartup="true"/>

    <!-- AutoCAD 2025 (R25) — same DLL, .NET 8 compatible when recompiled -->
    <RuntimeRequirements OS="Win32_64" Platform="AutoCAD"
                         SeriesMin="R25.0" SeriesMax="*"/>
    <ComponentEntry
        AppName="LightingAI.Plugin"
        Version="1.0.0"
        ModuleName="./Contents/LightingAI.Plugin.dll"
        LoadOnCommandInvocation="false"
        LoadOnAutoCADStartup="true"/>

  </Components>

</ApplicationPackage>
